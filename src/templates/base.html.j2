<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ page_title }}</title>
    <link rel="stylesheet" href="assets/styles.css">
  </head>
  <body>
    <header class="site-header">
      <div class="shell">
        <div class="brand-row">
          <div>
            <p class="eyebrow" data-i18n="header.eyebrow">Research Intel Radar</p>
            <h1 class="brand-title">research-radar</h1>
            <p class="brand-subtitle" data-i18n="header.subtitle">Incremental literature tracking for topics, baseline citations, and related work.</p>
          </div>
          <div class="header-tools">
            <div class="language-switcher" role="group" aria-label="Language switcher">
              <button type="button" class="lang-button" data-lang-switch="en">EN</button>
              <button type="button" class="lang-button" data-lang-switch="zh">中文</button>
            </div>
            <div class="meta-card">
              <p class="meta-label" data-i18n="header.latest_report">Latest report</p>
              <p class="meta-value">
                {% if summary.latest_report_date %}
                {{ summary.latest_report_date }}
                {% else %}
                <span data-i18n="header.no_runs_yet">No runs yet</span>
                {% endif %}
              </p>
            </div>
          </div>
        </div>
        <nav class="nav">
          <a href="index.html" data-i18n="nav.home">Home</a>
          <a href="topics.html" data-i18n="nav.topics">Topics</a>
          <a href="baselines.html" data-i18n="nav.baselines">Baselines</a>
          <a href="reports.html" data-i18n="nav.reports">Reports</a>
          <a href="about.html" data-i18n="nav.about">About</a>
        </nav>
      </div>
    </header>

    <main class="shell">
      {% block content %}{% endblock %}
    </main>

    <footer class="site-footer">
      <div class="shell footer-row">
        <span data-i18n="footer.generated">Generated from repository state and published with GitHub Pages.</span>
        <span data-i18n="footer.data_sources">Data: OpenAlex + Semantic Scholar</span>
      </div>
    </footer>
    <script src="assets/app.js"></script>
  </body>
</html>
