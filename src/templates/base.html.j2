<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ page_title }}</title>
    <link rel="stylesheet" href="assets/styles.css">
  </head>
  <body>
    <header class="site-header">
      <div class="shell">
        <div class="brand-row">
          <div>
            <p class="eyebrow">Research Intel Radar</p>
            <h1 class="brand-title">research-radar</h1>
            <p class="brand-subtitle">Incremental literature tracking for topics, baseline citations, and related work.</p>
          </div>
          <div class="meta-card">
            <p class="meta-label">Latest report</p>
            <p class="meta-value">{{ summary.latest_report_date or "No runs yet" }}</p>
          </div>
        </div>
        <nav class="nav">
          <a href="index.html">Home</a>
          <a href="topics.html">Topics</a>
          <a href="baselines.html">Baselines</a>
          <a href="reports.html">Reports</a>
          <a href="about.html">About</a>
        </nav>
      </div>
    </header>

    <main class="shell">
      {% block content %}{% endblock %}
    </main>

    <footer class="site-footer">
      <div class="shell footer-row">
        <span>Generated from repository state and published with GitHub Pages.</span>
        <span>Data: OpenAlex + Semantic Scholar</span>
      </div>
    </footer>
    <script src="assets/app.js"></script>
  </body>
</html>
